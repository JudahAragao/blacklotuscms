# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/blacklotuscms

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# Storage
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# S3/R2 (optional, only if STORAGE_DRIVER=s3 or r2)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_PUBLIC_URL=

# Sandbox
SANDBOX_MEMORY_LIMIT=512
SANDBOX_TIMEOUT=30

# Admin (used on first boot to create admin user)
ADMIN_EMAIL=admin@blacklotuscms.com
ADMIN_PASSWORD=admin123
